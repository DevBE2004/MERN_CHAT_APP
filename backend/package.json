{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc && cp ./package.json ./dist",
    "start:server": "nodemon --config nodemon.json",
    "start:worker": "nodemon --watch src --ext ts --exec \"ts-node --files ./src/worker.ts\"",
    "dev": "concurrently \"npm run start:server\" \"npm run start:worker\"",
    "start": "concurrently \"node dist/index.js\" \"node dist/worker.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@godaddy/terminus": "^4.12.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.7.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "peer": "^1.0.2",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie": "^0.6.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^22.18.10",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pino-http": "^5.8.4",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
