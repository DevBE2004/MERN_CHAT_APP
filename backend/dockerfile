FROM node:20-alpine AS builder
WORKDIR /backend
COPY package*.json ./
RUN npm install
COPY . .
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /backend
ENV NODE_ENV=production
COPY package*.json ./
RUN npm install --only=production
COPY --from=builder /backend/dist ./dist
EXPOSE 5000

# CMD ["node", "dist/index.js"]